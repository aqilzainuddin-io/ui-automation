<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="UI Automation Suite" parallel="methods" thread-count="2">
    
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.AddUserTest"/>
            <class name="tests.AddEmpTest"/>
            <class name="tests.PIMTest"/>
        </classes>
    </test>
    
    <test name="Sanity Tests">
        <groups>
            <run>
                <include name="sanity"/>
            </run>
        </groups>

        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.AddUserTest"/>
            <class name="tests.AddEmpTest"/>
            <class name="tests.PIMTest"/>
        </classes>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>

        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.AddUserTest"/>
            <class name="tests.AddEmpTest"/>
            <class name="tests.PIMTest"/>
        </classes>
    </test>

</suite>